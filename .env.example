# =========================================================
# ENV TEMPLATE — 9A Always Aspiring
# Salin file ini ke ".env" untuk pengembangan lokal (vercel dev),
# dan isi nilai yang sama di Vercel → Project Settings → Environment Variables
# untuk deployment production.
# JANGAN commit file ".env" asli ke GitHub.
# =========================================================

# --- Login Admin (SESSION LOGIN sederhana) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ganti-dengan-password-kuat

# --- Kunci rahasia untuk menandatangani cookie session (HMAC) ---
# Buat string acak panjang, contoh: openssl rand -hex 32
SESSION_SECRET=ganti-dengan-string-acak-panjang

# --- GitHub REST API (untuk commit album & information otomatis) ---
# Personal Access Token dengan scope "repo" (Contents: Read & Write)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GITHUB_OWNER=username-github-kamu
GITHUB_REPO=nama-repo-website-9a
BRANCH=main
